# Copy this file to ".env" and adjust the values.
#   cp .env.example .env       (Mac/Linux)
#   copy .env.example .env     (Windows CMD)
#
# docker-compose reads .env automatically. NEVER commit your real .env file.

# --- PostgreSQL credentials (used by both the db and web services locally) ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=customers

# --- Flask ---
# Generate a strong random value in production, e.g.:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Optional: single connection string ---
# When deploying to AWS RDS, set DATABASE_URL instead of the POSTGRES_* vars above.
# It overrides the individual settings when present.
# DATABASE_URL=postgresql://appuser:apppassword@your-rds-endpoint.us-east-2.rds.amazonaws.com:5432/customers
